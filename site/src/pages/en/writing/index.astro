---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Tag from '../../../components/core/Tag.astro';
import PostMeta from '../../../components/content/PostMeta.astro';
import { getPosts } from '../../../lib/posts';
import { postHref } from '../../../lib/routes';

const lang = 'en';
const posts = await getPosts(lang);
const topics = ['all', ...Array.from(new Set(posts.map((p) => p.data.topic)))];
---

<BaseLayout lang={lang} title="Writing" activeNav="writing" description="On technology, AI, and making them more evenly enjoyed.">
  <main class="db-reading" style="padding-top: var(--space-9); padding-bottom: var(--space-8);">
    <div class="db-eyebrow" style="margin-bottom: var(--space-3);">Writing · 文章</div>
    <h1 style="font-size: var(--text-3xl); letter-spacing: var(--tracking-tight); margin-bottom: var(--space-3);">Thinking in public</h1>
    <p style="font-family: var(--font-reading); font-size: var(--text-md); color: var(--text-body); margin-bottom: var(--space-6);">
      On technology, AI, and making them more evenly enjoyed.
    </p>

    <div style="display:flex; gap: var(--space-2); flex-wrap:wrap; margin-bottom: var(--space-7);">
      {topics.map((topic) => (
        <button
          class="db-tag"
          data-topic-filter={topic}
          data-variant={topic === 'all' ? 'accent' : undefined}
          style="cursor:pointer;"
        >
          {topic === 'all' ? 'All' : topic}
        </button>
      ))}
    </div>

    <div style="display:flex; flex-direction:column;">
      {posts.map((post, i) => (
        <article
          data-topic={post.data.topic}
          style={`padding: var(--space-6) 0; border-top: ${i === 0 ? 'none' : '1px solid var(--border-hairline)'};`}
        >
          <a
            href={postHref(lang, post.data.postSlug)}
            style="display:flex; flex-direction:column; gap: var(--space-2); text-decoration:none; color:inherit;"
          >
            <div style="display:flex; align-items:center; gap: var(--space-3);">
              <Tag variant="accent">{post.data.topic}</Tag>
              <PostMeta
                date={post.data.date}
                readingTime={post.data.reading}
                lang={lang}
                items={post.data.translated ? ['AI-tr'] : []}
              />
            </div>
            <h2 style="font-size: var(--text-xl); line-height: var(--leading-snug);">{post.data.title}</h2>
            <p style="font-family: var(--font-reading); font-size: var(--text-base); color: var(--text-body); line-height: 1.6; margin: 0; max-width: 56ch;">
              {post.data.lede}
            </p>
          </a>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<script src="../../../scripts/topic-filter.js"></script>
