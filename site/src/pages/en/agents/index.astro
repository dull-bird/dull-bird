---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BirdMark from '../../../components/brand/BirdMark.astro';
import { profile } from '../../../data/site';
import { getPosts } from '../../../lib/posts';
import { llmsDoc, jsonLdDoc } from '../../../lib/agentDoc';

const lang = 'en';
const posts = await getPosts(lang);
const llms = llmsDoc(lang, profile.en.bio, posts, Astro.site!);
const json = jsonLdDoc(lang, profile.en.bio, posts, Astro.site!);
---

<BaseLayout lang={lang} title="A view for AI agents" activeNav="agents" description="The same content, arranged for automated readers.">
  <main class="db-container" style="padding-top: var(--space-8); padding-bottom: var(--space-8); max-width: 880px;">
    <div style="display:flex; align-items:flex-start; gap: var(--space-4); margin-bottom: var(--space-6);">
      <BirdMark variant="stroke" size={40} color="var(--accent)" />
      <div style="flex:1;">
        <div class="db-eyebrow" style="margin-bottom: 6px;">Machine-readable · 机器可读</div>
        <h1 style="font-size: var(--text-2xl); letter-spacing: var(--tracking-tight); margin-bottom: var(--space-3);">A view for AI agents</h1>
        <p style="font-family: var(--font-reading); font-size: var(--text-md); color: var(--text-body); line-height: 1.6; max-width: 60ch;">
          The same content, arranged for automated readers. Stable links, clean semantics, ready to parse — compatible by intent, not by scraping.
        </p>
      </div>
    </div>

    <div style="display:flex; align-items:center; gap: var(--space-3); margin-bottom: var(--space-3);">
      <div class="db-langtoggle" role="group" aria-label="Format">
        <button data-format-toggle="llms" data-active="true">llms.txt</button>
        <button data-format-toggle="json">JSON-LD</button>
      </div>
      <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-faint);" data-format-caption="llms">
        GET /llms.txt · 200 OK · text/markdown
      </span>
      <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-faint);" data-format-caption="json" hidden>
        GET / · &lt;script type=application/ld+json&gt;
      </span>
    </div>

    <pre
      data-format-panel="llms"
      style="margin:0; font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.7; color: var(--text-body); background: var(--surface-well); border: 1px solid var(--border-hairline); border-radius: var(--radius-md); padding: var(--space-6); overflow: auto; white-space: pre-wrap; word-break: break-word;"
    ><code>{llms}</code></pre>
    <pre
      data-format-panel="json"
      hidden
      style="margin:0; font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.7; color: var(--text-body); background: var(--surface-well); border: 1px solid var(--border-hairline); border-radius: var(--radius-md); padding: var(--space-6); overflow: auto; white-space: pre-wrap; word-break: break-word;"
    ><code>{json}</code></pre>

    <p style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-faint); margin-top: var(--space-4);">
      Every page ships semantic HTML + JSON-LD; agents can follow links to the full text.
    </p>
  </main>
</BaseLayout>

<script src="../../../scripts/format-toggle.js"></script>
