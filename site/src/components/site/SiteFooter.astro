---
// The site footer: a bird mark, the William Gibson line the brand is
// built on, small nav columns, and a machine-readable hint for agents.
import BirdMark from '../brand/BirdMark.astro';

interface Props {
  lang: 'zh' | 'en';
  writingHref: string;
  aboutHref: string;
  agentsHref: string;
  feedHref: string;
}

const { lang, writingHref, aboutHref, agentsHref, feedHref } = Astro.props;

const line = lang === 'zh'
  ? '未来已来，只是分布不均。'
  : "The future is already here — it's just not evenly distributed.";

const cols = lang === 'zh'
  ? [
      { title: '站内', links: [['文章', writingHref], ['关于 · 此刻', aboutHref]] },
      { title: '订阅', links: [['RSS', feedHref]] },
      { title: '别处', links: [['GitHub', 'https://github.com/dull-bird'], ['给 AI 读', agentsHref]] },
    ]
  : [
      { title: 'Site', links: [['Writing', writingHref], ['About · Now', aboutHref]] },
      { title: 'Follow', links: [['RSS', feedHref]] },
      { title: 'Elsewhere', links: [['GitHub', 'https://github.com/dull-bird'], ['For agents', agentsHref]] },
    ];

const year = new Date().getFullYear();
---

<footer class="db-footer">
  <div class="db-footer__inner db-container">
    <div class="db-footer__brand">
      <BirdMark variant="line" size={40} />
      <p class="db-footer__quote">{line}</p>
      <p class="db-footer__cite">— William Gibson</p>
    </div>

    <div class="db-footer__cols">
      {cols.map((col) => (
        <div class="db-footer__col">
          <div class="db-footer__coltitle db-eyebrow">{col.title}</div>
          {col.links.map(([label, href]) => (
            <a href={href} class="db-footer__link db-link" data-muted="true">{label}</a>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="db-footer__base db-container">
    <span>© {year} 呆鸟小筑 · dull-bird</span>
    <span class="db-footer__built">笨鸟先飞 · built in the open</span>
  </div>
</footer>
