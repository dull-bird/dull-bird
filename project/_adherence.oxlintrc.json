{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/brand/**",
              "components/content/**",
              "components/core/**",
              "components/site/**",
              "ui_kits/personal-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Hanken Grotesk|IBM Plex Mono|Noto Serif SC|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Hanken Grotesk, IBM Plex Mono, Noto Serif SC, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='BirdMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|color|strokeWidth|animate|title|key|ref|className|style|children)$/]",
        "message": "<BirdMark> doesn't accept that prop. Declared props: variant, size, color, strokeWidth, animate, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='BirdMark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:line|solid|stroke)$/]",
        "message": "<BirdMark> variant must be one of 'line' | 'solid' | 'stroke'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|disabled|fullWidth|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, disabled, fullWidth, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|mark|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: tone, title, mark, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|quiet)$/]",
        "message": "<Callout> tone must be one of 'accent' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|flat|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: href, flat, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LangToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|labels|key|ref|className|style|children)$/]",
        "message": "<LangToggle> doesn't accept that prop. Declared props: value, onChange, labels."
      },
      {
        "selector": "JSXOpeningElement[name.name='LangToggle'] > JSXAttribute[name.name='value'] > Literal[value!=/^(?:zh|en)$/]",
        "message": "<LangToggle> value must be one of 'zh' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|readingTime|lang|items|key|ref|className|style|children)$/]",
        "message": "<PostMeta> doesn't accept that prop. Declared props: date, readingTime, lang, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostMeta'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:zh|en)$/]",
        "message": "<PostMeta> lang must be one of 'zh' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Prose'] > JSXAttribute > JSXIdentifier[name!=/^(?:lang|html|children|key|ref|className|style|children)$/]",
        "message": "<Prose> doesn't accept that prop. Declared props: lang, html, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Prose'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:zh|en)$/]",
        "message": "<Prose> lang must be one of 'zh' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: title, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|href|iconLeft|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, href, iconLeft, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|bare)$/]",
        "message": "<Tag> variant must be one of 'default' | 'accent' | 'bare'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|muted|children|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: href, muted, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:lang|size|showMark|markVariant|orientation|tagline|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: lang, size, showMark, markVariant, orientation, tagline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:zh|en)$/]",
        "message": "<Wordmark> lang must be one of 'zh' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='markVariant'] > Literal[value!=/^(?:line|solid|stroke)$/]",
        "message": "<Wordmark> markVariant must be one of 'line' | 'solid' | 'stroke'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|stacked)$/]",
        "message": "<Wordmark> orientation must be one of 'horizontal' | 'stacked'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
